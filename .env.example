# --- HUB (server) — this .env is only needed on the machine running the hub ---
# Port the hub listens on
PORT=8787
# Shared team token — every client must send this as X-Auth-Token
COLLAB_TOKEN=change-me-to-a-long-random-string
# SQLite database file
DB_PATH=./collab.db
# Seconds before an agent is considered offline / presence expires
PRESENCE_TTL_SEC=120

# --- CLIENT (Claude Code) — do NOT put these here; export them in your shell ---
# The committed .mcp.json / .claude/settings.json read these from the environment:
#   export COLLAB_TOKEN=<shared-token>   # same value as the hub's COLLAB_TOKEN
#   export AGENT_ID=<your-unique-handle> # e.g. minsu-claude
#   export COLLAB_URL=http://<macmini-ip>:8787   # optional; overrides .mcp.json default
